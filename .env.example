# ─── LLM provider (OpenAI-compatible) ───────────────────────────────────────
# The agent is provider-agnostic: set these three values for any OpenAI-compatible
# endpoint. Two ready-to-use options:
#
# (A) Demo default — Groq (sub-2s responses). Get a key at console.groq.com:
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile
#
# (B) Local & free — Ollama (fully offline). For qwen3, set DISABLE_THINKING=true:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3:14b

# Suppress Qwen3 "thinking" tokens on tool-calling turns. Leave false for llama;
# set true when using a local qwen3 model.
LLM_DISABLE_THINKING=false
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ─── Embeddings (local, free) ───────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
EMBED_BASE_URL=http://localhost:11434

# ─── Storage paths ──────────────────────────────────────────────────────────
SQLITE_PATH=app/data/retail.db
CHROMA_PATH=app/data/chroma

# ─── App ────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
