# ─── LLM provider (OpenAI-compatible) ───────────────────────────────────────
# The agent is provider-agnostic: set these three values for any OpenAI-compatible
# endpoint. Two ready-to-use options:
#
# (A) Local & free — Ollama (default, fully offline):
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama          # any non-empty string for local Ollama
LLM_MODEL=qwen3:14b
#
# (B) Fast & free-tier — Groq (sub-2s responses). Get a key at console.groq.com:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_groq_key_here
# LLM_MODEL=qwen/qwen3-32b

# Disable Qwen3's "thinking" tokens on tool-calling turns (faster, cleaner parsing).
LLM_DISABLE_THINKING=true
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# ─── Embeddings (local, free) ───────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
EMBED_BASE_URL=http://localhost:11434

# ─── Storage paths ──────────────────────────────────────────────────────────
SQLITE_PATH=app/data/retail.db
CHROMA_PATH=app/data/chroma

# ─── App ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
